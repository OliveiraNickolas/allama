# Example: llama.cpp backend (GGUF model)
backend = "llama.cpp"
model = "/path/to/your/model.gguf"
# mmproj = "/path/to/mmproj.gguf"   # Optional: enable vision support
gpu_id = 0                           # Pin to a specific GPU (remove to auto-select)
n_ctx = 131072
n_batch = "1024"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--no-warmup", "--jinja", "--flash-attn", "on",
    "--cache-type-k", "q8_0", "--cache-type-v", "q8_0",
    "--ubatch-size", "512", "--threads-batch", "16", "--cont-batching"
]
