backend = "llama.cpp"
model = "/path/to/Models/Qwen3.6-35B-A3B-Uncensored-GGUF/model-Q4_K_M.gguf"
# mmproj is optional — include for vision/multimodal support
# mmproj = "/path/to/Models/Qwen3.6-35B-A3B-Uncensored-GGUF/mmproj-f16.gguf"

# Pin to a specific GPU (optional — remove to let allma auto-select)
# gpu_id = 1

n_ctx = 98304
n_batch = "1024"
n_gpu_layers = "-1"
n_threads = "8"

extra_args = [
    "--jinja",
    "--flash-attn", "on",
    "--cache-type-k", "q4_0",
    "--cache-type-v", "q4_0",
    "--ubatch-size", "512",
    "--threads-batch", "16",
    "--cont-batching",
    "--defrag-thold", "0.1"
]
