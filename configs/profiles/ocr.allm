# OCR Profile: Qwen 3.5 Vision 7B
# Use for: Extract text from apostilas, scans, documents
# Hardware: Single RTX 3090 GPU (10-12GB VRAM)
# Expected: 1-2s per page, 95%+ accuracy

backend = "vllm"
path = "/path/to/models/Qwen3.5-Vision-7B-FP8"
tokenizer = "/path/to/models/Qwen3.5-Vision-7B-FP8"
tensor_parallel = 1
gpu_memory_utilization = 0.80
max_model_len = 4096
max_num_seqs = 1
max_num_batched_tokens = 2048
extra_args = ["--image-input-type", "float"]

[sampling]
temperature = 0.2
top_p = 0.8
repetition_penalty = 1.0

[preprocessing]
# Image optimization (from Reddit findings)
target_height = 256
target_width = 256
quality = "high"
preserve_layout = true
