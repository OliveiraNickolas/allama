# Research Profile: Qwen 3.5 27B
# Use for: Websearch, tool calling, MCP integration, analysis
# Hardware: Single RTX 3090 GPU (20-22GB VRAM), leaves GPU1 free
# Expected: 1-2s latency, good tool use and reasoning

backend = "vllm"
path = "/path/to/models/Qwen3.5-27B-FP8"
tokenizer = "/path/to/models/Qwen3.5-27B-FP8"
tensor_parallel = 1
gpu_memory_utilization = 0.88
max_model_len = 16384
max_num_seqs = 4
max_num_batched_tokens = 8192
extra_args = ["--enable-auto-tool-choice", "--tool-call-parser", "qwen"]

[sampling]
temperature = 0.7
top_p = 0.85
top_k = 50
presence_penalty = 0.1

[tools]
enable_tool_calling = true
max_tool_calls = 5
tool_timeout = 30
