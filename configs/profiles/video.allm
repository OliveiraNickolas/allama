# Video Profile: Qwen 3.5 Vision 7B with Chunking
# Use for: Analyze videos, extract keyframes, create summaries
# Hardware: Single RTX 3090 GPU (10-12GB VRAM)
# Expected: 1-1.5s per frame, maintains context across chunks

backend = "vllm"
path = "/path/to/models/Qwen3.5-Vision-7B-FP8"
tokenizer = "/path/to/models/Qwen3.5-Vision-7B-FP8"
tensor_parallel = 1
gpu_memory_utilization = 0.80
max_model_len = 4096
max_num_seqs = 1
max_num_batched_tokens = 2048

[sampling]
temperature = 0.7
top_p = 0.9
top_k = 50

[preprocessing]
# Video-specific optimization (from Reddit testing)
target_height = 360
target_fps = 1
chunk_duration = 300  # 5 minutes max per chunk
chunk_overlap = 5     # 5 seconds overlap for context preservation
quality = "balanced"

[chunking]
strategy = "temporal"
summarize_chunks = true
merge_overlap = true
