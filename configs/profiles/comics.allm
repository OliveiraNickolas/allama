# Comics/Quadrinhos Profile: Qwen 3.5 Vision 7B
# Use for: Extract text from speech bubbles, analyze panels
# Hardware: Single RTX 3090 GPU (10-12GB VRAM)
# Expected: 0.8-1.5s per panel, excellent speech recognition

backend = "vllm"
path = "/path/to/models/Qwen3.5-Vision-7B-FP8"
tokenizer = "/path/to/models/Qwen3.5-Vision-7B-FP8"
tensor_parallel = 1
gpu_memory_utilization = 0.80
max_model_len = 2048
max_num_seqs = 4
max_num_batched_tokens = 2048

[sampling]
temperature = 0.5
top_p = 0.9
top_k = 50

[preprocessing]
# Keep higher resolution for small text in bubbles
target_height = 512
target_width = 512
detect_panels = true
enhance_contrast = true
quality = "high"

[vision]
focus_on_text = true
detect_speech_bubbles = true
