# Coding Profile: Qwen 3.5 35B with Tensor Parallel
# Use for: Algorithm design, complex reasoning, long code context
# Hardware: Both RTX 3090 (TP=2), 26-28GB VRAM
# Expected: 2-3s latency, excellent quality

backend = "vllm"
path = "/path/to/models/Qwen3.5-35B-FP8"
tokenizer = "/path/to/models/Qwen3.5-35B-FP8"
tensor_parallel = 2
gpu_memory_utilization = 0.85
max_model_len = 32768
max_num_seqs = 2
max_num_batched_tokens = 16384
extra_args = ["--enable-auto-tool-choice"]

[sampling]
temperature = 0.3
top_p = 0.8
top_k = 40
presence_penalty = 0.1
